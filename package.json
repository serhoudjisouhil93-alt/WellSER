{
  "name": "wellser",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:fsevents --external:fs --external:path --external:express --external:vite",
    "start": "node dist/server.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^0.21.0",
    "d3": "^7.9.0",
    "express": "^4.18.2",
    "lucide-react": "^0.344.0",
    "motion": "^11.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "vite": "^5.1.4"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "esbuild": "^0.20.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.2.2"
  }
}
